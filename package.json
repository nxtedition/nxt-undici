  "main": "lib/index.js",
  "type": "module",
  "files": [
    "lib/*"
  ],
  "dependencies": {
    "@nxtedition/scheduler": "^4.2.2",
    "@nxtedition/trace": "^1.1.2",
    "@nxtedition/undici": "^11.1.9",
    "fast-querystring": "^1.1.2",
    "http-errors": "^2.0.1",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.6.0",
    "eslint-plugin-n": "^18.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "mitata": "^1.0.34",
    "pino": "^10.3.1",
    "pinst": "^3.0.0",
    "prettier": "^3.9.5",
    "send": "^1.2.1",
    "tap": "^21.7.4",
    "undici-types": "^8.7.0"
  },
  "scripts": {
    "prepare": "husky",
    "prepublishOnly": "pinst --disable",
    "postpublish": "pinst --enable",
    "test": "tap test",
    "test:cache-tests": "node cache-tests/run.js --ci && node cache-tests/run.js --ci --heuristic",
    "test:coverage": "tap test --coverage-report=text --coverage-report=html"
  },
  "lint-staged": {
    "*.{js,jsx,md,ts}": [
      "eslint",
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true
  }
}
